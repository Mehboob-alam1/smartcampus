# Used by `vercel dev` locally and must be set in Vercel → Project → Settings → Environment Variables

# PostgreSQL (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:pass@host:5432/smartcampus

# Long random string for signing JWTs
JWT_SECRET=change-this-to-a-long-random-string

# Public URL of your Python face service (no trailing slash)
# Example: https://smartcampus-face.onrender.com
PYTHON_FACE_URL=http://127.0.0.1:5000
